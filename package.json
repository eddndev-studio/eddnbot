{
  "name": "eddnbot",
  "private": true,
  "packageManager": "pnpm@10.6.2",
  "engines": {
    "node": ">=22"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "db:generate": "turbo db:generate",
    "db:migrate": "turbo db:migrate",
    "db:studio": "turbo db:studio",
    "docker:up": "podman-compose -f tooling/docker/docker-compose.yml up -d",
    "docker:down": "podman-compose -f tooling/docker/docker-compose.yml down"
  },
  "devDependencies": {
    "eslint": "^10.0.2",
    "prettier": "^3.8.1",
    "turbo": "^2.8.13"
  }
}
